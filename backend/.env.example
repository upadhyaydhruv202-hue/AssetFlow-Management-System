# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/assetflow?schema=public"

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET="assetflow-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="assetflow-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Email (SMTP) — REQUIRED for real email delivery ───
#
# Gmail setup (recommended):
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create App Password: https://myaccount.google.com/apppasswords
#      Select "Mail" → "Other" → name it "AssetFlow"
#   3. Copy the 16-character password (no spaces) into SMTP_PASS below
#   4. Set SMTP_USER to your Gmail address
#   5. Set SMTP_FROM to match your Gmail (required by Gmail)
#
# Outlook/Hotmail:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=AssetFlow <your-email@gmail.com>

# ─── Google Sign-In (OAuth) ─────────────────────────────
#
# Setup:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a project (or pick an existing one)
#   3. "Create Credentials" → "OAuth client ID" → Application type: "Web application"
#   4. Authorized JavaScript origins: http://localhost:5173
#   5. Copy the Client ID (ends with .apps.googleusercontent.com) below
#
GOOGLE_CLIENT_ID=
